  projectCode     String?
  quantity        Decimal? @db.Decimal(18, 6)
  unitPrice       Decimal? @db.Decimal(18, 6)
  totalAmount     Decimal? @db.Decimal(18, 6)
  balanceQty      Decimal? @db.Decimal(18, 6)
  transactionDate DateTime @default(now())
  remark          String?
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([materialCode])
  @@index([warehouseCode])
  @@index([transactionDate])
  @@map("inventory_transaction")
}

model AdjustOrder {
  id              String         @id @default(cuid())
  tenantId        String
  orderNo         String
  checkOrderId    String?
  checkOrderNo    String?
  materialName    String?
  warehouseName   String?
  adjustQty       Decimal?       @db.Decimal(18,6)
  adjustReason    String?
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@map("adjust_order")
}

model CompleteReport {
  id              String         @id @default(cuid())
  tenantId        String
  reportNo        String
  sourceType      String?
  productionOrderId String?
  productionOrderNo String?
  materialCode    String?
  materialName    String?
  spec            String?
  unit            String?
  plannedQty      Decimal?       @db.Decimal(18,6)
  actualQty       Decimal?       @db.Decimal(18,6)
  deptName        String?
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines           CompleteReportLine[]

  @@unique([tenantId, reportNo])
  @@index([tenantId])
  @@map("complete_report")
}

model CompleteReportLine {
  id              String    @id @default(cuid())
  tenantId        String
  reportId        String
  lineNo          Int
  materialCode    String?
  materialName    String?
  spec            String?
  unit            String?
  plannedQty      Decimal?  @db.Decimal(18, 6)
  actualQty       Decimal?  @db.Decimal(18, 6)
  warehouseCode   String?
  remark          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  report          CompleteReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([reportId])
  @@map("complete_report_line")
}
