generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== 枚举 ====================

enum ApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum BusinessStatus {
  PENDING
  IN_PROGRESS
  PARTIAL
  COMPLETED
  CLOSED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PENDING_SHIP
  PARTIAL_SHIP
  FULLY_SHIPPED
  CLOSED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PENDING_RECEIPT
  PARTIAL_RECEIPT
  FULLY_RECEIVED
  CLOSED
}

enum ProductionOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PENDING_ISSUE
  ISSUING
  IN_PRODUCTION
  PENDING_STOCK
  COMPLETED
  CLOSED
}

enum InspectionStatus {
  DRAFT
  PENDING
  INSP_IN_PROGRESS
  QUALIFIED
  UNQUALIFIED
}

enum MaterialType {
  PHYSICAL
  VIRTUAL
}

enum CommonStatus {
  ACTIVE
  INACTIVE
}

enum StockChangeType {
  IN
  OUT
}

// ==================== 系统基础表 ====================

model Tenant {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  users       User[]
  roles       Role[]
  departments Department[]
  menus       Menu[]
  dictionaries Dictionary[]
  materialCategories MaterialCategory[]
  measurementUnits   MeasurementUnit[]
  materials          Material[]
  materialParam      MaterialParam?
  projects           Project[]
  suppliers          Supplier[]
  customers          Customer[]
  quotations         Quotation[]
  demandPlans        DemandPlan[]
  inboundOrders      InboundOrder[]
  outboundOrders     OutboundOrder[]
  transferOrders     TransferOrder[]
  lendOrders         LendOrder[]
  scrapOrders        ScrapOrder[]
  warehouses         Warehouse[]
  costLedgers        CostLedger[]
  inventory          Inventory[]
  boms               Bom[]
  productionOrders   ProductionOrder[]
  inspections        Inspection[]
  preOrders          PreOrder[]
  salesOrders        SalesOrder[]
  salesShipments     SalesShipment[]
  salesReturns       SalesReturn[]
  contracts          Contract[]

  @@map("tenant")
}

model User {
  id            String        @id @default(cuid())
  tenantId      String
  username      String        @unique
  password      String
  name          String
  email         String?
  phone         String?
  departmentId  String?
  dataScope     String?
  sortOrder     Int           @default(0)
  status        CommonStatus  @default(ACTIVE)
  lastLoginAt   DateTime?
  lastLoginIp   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department    Department?   @relation(fields: [departmentId], references: [id])
  userRoles     UserRole[]
  operationLogs OperationLog[]
  loginLogs     LoginLog[]

  @@index([tenantId])
  @@index([departmentId])
  @@map("user")
}

model Role {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  sortOrder   Int           @default(0)
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserRole[]
  permissions Permission[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("role")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_role")
}

model Permission {
  id          String   @id @default(cuid())
  roleId      String
  menuId      String?
  permission  String
  type        String
  createdAt   DateTime @default(now())

  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu        Menu?    @relation(fields: [menuId], references: [id], onDelete: SetNull)

  @@unique([roleId, permission])
  @@index([roleId])
  @@index([menuId])
  @@map("permission")
}

model Department {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  parentId    String?
  sortOrder   Int           @default(0)
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Department?   @relation("DepartmentTree", fields: [parentId], references: [id])
  children    Department[]  @relation("DepartmentTree")
  users       User[]

  @@index([tenantId])
  @@index([parentId])
  @@map("department")
}

model Menu {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  parentId    String?
  path        String?
  icon        String?
  component   String?
  sortOrder   Int           @default(0)
  type        String
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Menu?         @relation("MenuTree", fields: [parentId], references: [id])
  children    Menu[]        @relation("MenuTree")
  permissions Permission[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@map("menu")
}

model Dictionary {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  parentId    String?
  value       String?
  remark      String?
  hint        String?
  sortOrder   Int           @default(0)
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Dictionary?   @relation("DictionaryTree", fields: [parentId], references: [id])
  children    Dictionary[]  @relation("DictionaryTree")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@map("dictionary")
}

model OperationLog {
  id            String   @id @default(cuid())
  userId        String?
  username      String?
  moduleName    String?
  businessName  String?
  method        String?
  ipAddress     String?
  requestUrl    String?
  requestMethod String?
  requestParams Json?
  responseResult Json?
  status        Int?
  errorMsg      String?
  costTime      Int?
  operatedAt    DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([operatedAt])
  @@index([moduleName, businessName])
  @@map("operation_log")
}

model LoginLog {
  id            String   @id @default(cuid())
  userId        String?
  username      String?
  ipAddress     String?
  loginLocation String?
  browser       String?
  os            String?
  status        Int?
  msg           String?
  loginTime     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([loginTime])
  @@map("login_log")
}

// ==================== 公共基础表 ====================

model MaterialCategory {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  parentId    String?
  sortOrder   Int           @default(0)
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      MaterialCategory? @relation("CategoryTree", fields: [parentId], references: [id])
  children    MaterialCategory[] @relation("CategoryTree")
  materials   Material[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@map("material_category")
}

model MaterialParam {
  id              String   @id @default(cuid())
  tenantId        String
  codeFormat      String?  // 物料编码格式，如 "MAT{yyyyMM}{seq:4}"
  allowDuplicateName Boolean @default(false)
  autoApproval    Boolean  @default(false)
  defaultStatus   CommonStatus @default(ACTIVE)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@map("material_param")
}

model Supplier {
  id              String        @id @default(cuid())
  tenantId        String
  code            String
  name            String
  contactPerson   String?
  contactPhone    String?
  contactEmail    String?
  address         String?
  creditLevel     String?
  taxId           String?
  bankName        String?
  bankAccount     String?
  status          CommonStatus  @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("supplier")
}

model Customer {
  id            String        @id @default(cuid())
  tenantId      String
  code          String
  name          String
  industry      String?
  valueLevel    String?
  creditLevel   String?
  contactPerson String?
  contactPhone  String?
  contactEmail  String?
  address       String?
  status        CommonStatus  @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("customer")
}

model DemandPlan {
  id              String         @id @default(cuid())
  tenantId        String
  planNo          String
  planName        String
  demandSource    String?
  demandUse       String?
  projectId       String?
  projectName     String?
  requiredDate    DateTime?
  totalQuantity   Decimal?       @db.Decimal(18,6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING")
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, planNo])
  @@index([tenantId])
  @@map("demand_plan")
}

model PreOrder {
  id              String         @id @default(cuid())
  tenantId        String
  orderNo         String
  orderName       String
  contractId      String?
  contractName    String?
  customerId      String?
  customerName    String?
  totalAmount     Decimal?       @db.Decimal(18, 6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@map("pre_order")
}

model Quotation {
  id              String         @id @default(cuid())
  tenantId        String
  quotationNo     String
  quotationName   String
  customerId      String?
  customerName    String?
  departmentName  String?
  responsibleName String?
  validUntil      DateTime?
  totalAmount     Decimal?       @db.Decimal(18, 6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  status          CommonStatus   @default(ACTIVE)
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, quotationNo])
  @@index([tenantId])
  @@map("quotation")
}

model SalesOrder {
  id              String         @id @default(cuid())
  tenantId        String
  orderNo         String
  orderName       String
  customerId      String?
  customerName    String?
  projectName     String?
  contractName    String?
  orderType       String?
  orderDate       DateTime       @default(now())
  deliveryDate    DateTime?
  totalAmount     Decimal?       @db.Decimal(18, 6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING_SHIP")
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@map("sales_order")
}

model SalesShipment {
  id              String         @id @default(cuid())
  tenantId        String
  shipmentNo      String
  orderId         String?
  orderNo         String?
  customerName    String?
  shipmentDate    DateTime       @default(now())
  totalQuantity   Decimal?       @db.Decimal(18, 6)
  totalAmount     Decimal?       @db.Decimal(18, 6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING")
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, shipmentNo])
  @@index([tenantId])
  @@map("sales_shipment")
}

model SalesReturn {
  id              String         @id @default(cuid())
  tenantId        String
  returnNo        String
  shipmentId      String?
  shipmentNo      String?
  customerName    String?
  returnDate      DateTime       @default(now())
  totalQuantity    Decimal?       @db.Decimal(18, 6)
  totalAmount     Decimal?       @db.Decimal(18, 6)
  returnReason    String?
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING")
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, returnNo])
  @@index([tenantId])
  @@map("sales_return")
}

model Contract {
  id                  String         @id @default(cuid())
  tenantId            String
  code                String
  name                String
  type                String         // 销售合同/采购合同
  isProjectContract   Boolean        @default(false)
  isFrameworkContract Boolean        @default(false)
  projectId           String?
  customerName        String?
  supplierName        String?
  startDate           DateTime?
  endDate             DateTime?
  totalAmount         Decimal?       @db.Decimal(18, 6)
  approvalStatus      ApprovalStatus @default(DRAFT)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("contract")
}

model Project {
  id              String         @id @default(cuid())
  tenantId        String
  code            String
  name            String
  source          String?
  organizationId  String?
  approvalStatus  ApprovalStatus @default(DRAFT)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("project")
}

model MeasurementUnit {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  symbol      String?
  sortOrder   Int           @default(0)
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  materials   Material[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("measurement_unit")
}

model Material {
  id               String        @id @default(cuid())
  tenantId         String
  code             String         // 物料编号
  name             String         // 物料名称 *
  specification    String?        // 规格型号
  externalCode     String?        // 外部编码
  categoryId       String         // 1级分类 *
  materialType     MaterialType   @default(PHYSICAL) // 物料性质 *
  materialProperty String?        // 物料属性
  productCategory  String?        // 产品分类 *
  unitId           String         // 计量单位 *
  unifiedUnit      Boolean        @default(true) // 是否统一计量单位
  sortOrder        Int            @default(0) // 排序
  status           CommonStatus   @default(ACTIVE) // 状态
  remark           String?        // 备注

  // 采购信息
  defaultSupplier    String?      // 默认供应商
  defaultPurchaser   String?      // 默认采购员
  minPurchaseQty     Decimal?     @db.Decimal(18,6) // 最小采购数量
  plannedPrice       Decimal?     @db.Decimal(18,6) // 计划采购价
  requiredManufacturer String?    // 要求生产厂家
  excludedManufacturer String?    // 排除厂家
  responsiblePerson  String?      // 主办人

  // 质检信息
  needInspection     Boolean      @default(false) // 是否质检
  defectRateLimit    Decimal?     @db.Decimal(5,2) // 不合格比例下限(%)

  // 销售信息
  defaultSalesperson String?      // 默认销售员
  minOrderQty        Decimal?     @db.Decimal(18,6) // 最小起订数量

  // 仓储信息
  defaultWarehouseId String?      // 默认存储仓库
  safetyStockQty     Decimal?     @db.Decimal(18,6) // 安全库存数量
  maxStockQty        Decimal?     @db.Decimal(18,6) // 最高库存数量
  minStockQty        Decimal?     @db.Decimal(18,6) // 最低库存数量
  batchManaged       Boolean      @default(false) // 是否批次管理
  shelfLifeManaged   Boolean      @default(false) // 是否效期管理
  remainingShelfLife Int?         // 剩余有效期(天)
  serialManaged      Boolean      @default(false) // 是否序列号/单品码管理

  // 生产信息
  directProduction   Boolean      @default(false) // 是否直接生产
  planAttribute      String?      // 计划属性 *
  economicBatch      Decimal?     @db.Decimal(18,6) // 经济批量
  batchMultiple      Decimal?     @db.Decimal(18,6) // 批量倍量
  lossRate           Decimal?     @db.Decimal(5,2) // 损耗率(%)
  defaultDeptId      String?      // 默认生产部门
  issueMethod        String?      // 发料方式

  // 工时信息
  prodStdQty         Decimal?     @db.Decimal(18,6) // 生产标准工时-生产数量
  prodStdHours       Decimal?     @db.Decimal(5,2) // 单人用时(生产)
  repairStdQty       Decimal?     @db.Decimal(18,6) // 检修标准工时-检修数量
  repairStdHours     Decimal?     @db.Decimal(5,2) // 单人用时(检修)
  maintStdQty        Decimal?     @db.Decimal(18,6) // 维修标准工时-维修数量
  maintStdHours      Decimal?     @db.Decimal(5,2) // 单人工时(维修)

  approvalStatus   ApprovalStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category         MaterialCategory @relation(fields: [categoryId], references: [id])
  unit             MeasurementUnit @relation(fields: [unitId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, categoryId])
  @@index([unitId])
  @@map("material")
}

model Bom {
  id              String         @id @default(cuid())
  tenantId        String
  code            String
  name            String
  materialId      String?
  materialName    String?
  version         String?
  quantity        Decimal?       @db.Decimal(18,6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("bom")
}

model InboundOrder {
  id              String         @id @default(cuid())
  tenantId        String
  orderNo         String
  materialName    String?
  specification   String?
  quantity        Decimal?       @db.Decimal(18,6)
  qualifiedQty    Decimal?       @default(0) @db.Decimal(18,6)
  unqualifiedQty  Decimal?       @default(0) @db.Decimal(18,6)
  warehouseId     String?
  warehouseName   String?
  unitPrice       Decimal?       @db.Decimal(18,6)
  totalAmount     Decimal?       @db.Decimal(18,6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING")
  receiptDate     DateTime       @default(now())
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@map("inbound_order")
}

model OutboundOrder {
  id              String         @id @default(cuid())
  tenantId        String
  orderNo         String
  materialName    String?
  specification   String?
  quantity        Decimal?       @db.Decimal(18,6)
  warehouseId     String?
  warehouseName   String?
  unitPrice       Decimal?       @db.Decimal(18,6)
  totalAmount     Decimal?       @db.Decimal(18,6)
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING")
  shipmentDate    DateTime       @default(now())
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@map("outbound_order")
}

model Warehouse {
  id          String        @id @default(cuid())
  tenantId    String
  code        String
  name        String
  address     String?
  sortOrder   Int           @default(0)
  status      CommonStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouse")
}

model CostLedger {
  id              String   @id @default(cuid())
  tenantId        String
  transactionNo   String
  transactionType String   // 入库/出库/调拨/调整
  materialName    String?
  quantity        Decimal? @db.Decimal(18,6)
  unitPrice       Decimal? @db.Decimal(18,6)
  totalAmount     Decimal? @db.Decimal(18,6)
  transactionDate DateTime @default(now())
  remark          String?
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("cost_ledger")
}

model Inventory {
  id            String   @id @default(cuid())
  tenantId      String
  materialId    String?
  materialName  String?
  warehouseId   String?
  warehouseName String?
  locationCode  String?
  batchNo       String?
  quantity      Decimal  @db.Decimal(18,6)
  availableQty  Decimal  @db.Decimal(18,6)
  lockedQty     Decimal  @default(0) @db.Decimal(18,6)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, materialId, warehouseId, batchNo])
  @@index([tenantId])
  @@map("inventory")
}

model ProductionOrder {
  id              String         @id @default(cuid())
  tenantId        String
  orderNo         String
  orderName       String
  bomId           String?
  materialId      String?
  materialName    String?
  quantity        Decimal?       @db.Decimal(18,6)
  departmentId    String?
  departmentName  String?
  startDate       DateTime?
  endDate         DateTime?
  approvalStatus  ApprovalStatus @default(DRAFT)
  businessStatus  String         @default("PENDING_ISSUE")
  remark          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@map("production_order")
}

model Inspection {
